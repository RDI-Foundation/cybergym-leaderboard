{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "pbfuzz_purple_agent_card_url": {
        "type": "string",
        "description": "URL advertised in the Agent Card (how the green agent / scenario resolves this purple agent)."
      },
      "pbfuzz_purple_agent_cursor_api_key": {
        "type": "string",
        "secret": true,
        "description": "Optional. Cursor Dashboard API key when not using cursor_auth."
      },
      "pbfuzz_purple_agent_cursor_auth": {
        "type": "string",
        "secret": true,
        "description": "Standard base64 of the host file ~/.config/cursor/auth.json (raw bytes). Server decodes and writes $HOME/.config/cursor/auth.json."
      },
      "pbfuzz_purple_agent_cursor_model": {
        "type": "string",
        "description": "Optional. Passed to cursor-agent as --model (e.g. haiku-4.5)."
      }
    },
    "required": [
      "pbfuzz_purple_agent_card_url"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "tasks": [
            "arvo:47101"
          ],
          "level": "level3",
          "num_workers": 2
        },
        "participant_roles": {
          "green": "green",
          "purple1": "pbfuzz_purple_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://github.com/RDI-Foundation/cybergym-green/raw/refs/heads/main/amber-manifest.json5",
      "config": {}
    },
    "pbfuzz_purple_agent": {
      "manifest": "https://raw.githubusercontent.com/sgzeng/pbfuzz/refs/heads/master/amber-manifest.json5",
      "config": {
        "card_url": "${config.pbfuzz_purple_agent_card_url}",
        "cursor_api_key": "${config.pbfuzz_purple_agent_cursor_api_key}",
        "cursor_auth": "${config.pbfuzz_purple_agent_cursor_auth}",
        "cursor_model": "${config.pbfuzz_purple_agent_cursor_model}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#pbfuzz_purple_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d6508-40a2-7d43-b07b-4c43cd4fba45",
      "pbfuzz_purple_agent": "019df17f-70a9-74f2-8a44-c0e8f29c621a"
    }
  },
  "experimental_features": [
    "docker"
  ]
}