{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_anthropic_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_nvidia_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "agent_anthropic_api_key",
      "agent_nvidia_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "tasks": [
            "arvo:47101",
            "oss-fuzz:42535201"
          ],
          "level": "level1",
          "num_workers": 2
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://github.com/RDI-Foundation/cybergym-green/raw/refs/heads/main/amber-manifest.json5",
      "config": {}
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/tenalirama2005/cybergym-agentx/master/amber-manifest.json5",
      "config": {
        "anthropic_api_key": "${config.agent_anthropic_api_key}",
        "nvidia_api_key": "${config.agent_nvidia_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d6508-40a2-7d43-b07b-4c43cd4fba45",
      "agent": "019db6ff-8f2a-7093-8b02-8579feb7fa00"
    }
  },
  "experimental_features": [
    "docker"
  ]
}