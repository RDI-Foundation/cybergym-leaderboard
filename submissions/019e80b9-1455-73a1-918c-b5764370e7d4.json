{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_openai_api_key": {
        "type": "string",
        "secret": true,
        "description": "OpenAI API key injected by AgentBeats/Amber at runtime."
      },
      "agent_pi_bench_model": {
        "type": "string",
        "description": "Model used by the Pi-Bench purple agent path, e.g. gpt-4.1 or gpt-4o-mini."
      }
    },
    "required": [
      "agent_openai_api_key",
      "agent_pi_bench_model"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "tasks": [
            "arvo:47101",
            "oss-fuzz:42535201"
          ],
          "level": "level5",
          "num_workers": 200
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://github.com/RDI-Foundation/cybergym-green/raw/refs/heads/main/amber-manifest.json5",
      "config": {}
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/ivanjojo369/AegisForge_agent/main/amber/amber-manifest-aegisforge-purple.json5",
      "config": {
        "openai_api_key": "${config.agent_openai_api_key}",
        "pi_bench_model": "${config.agent_pi_bench_model}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d6508-40a2-7d43-b07b-4c43cd4fba45",
      "agent": "019e2db7-2a23-7673-a2f4-e09ec4bbf4d1"
    }
  },
  "experimental_features": [
    "docker"
  ]
}