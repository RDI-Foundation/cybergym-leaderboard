{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_azure_openai_api_version": {
        "type": "string"
      },
      "agent_azure_openai_deployment": {
        "type": "string"
      },
      "agent_azure_openai_endpoint": {
        "type": "string"
      },
      "agent_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "agent_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "tasks": [
            "arvo:47101",
            "oss-fuzz:42535201"
          ],
          "level": "level1",
          "num_workers": 2
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://github.com/RDI-Foundation/cybergym-green/raw/refs/heads/main/amber-manifest.json5",
      "config": {}
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/sharathbaddam/AgentWhetters-cybergym/refs/heads/main/amber-manifest.json5",
      "config": {
        "azure_openai_api_version": "${config.agent_azure_openai_api_version}",
        "azure_openai_deployment": "${config.agent_azure_openai_deployment}",
        "azure_openai_endpoint": "${config.agent_azure_openai_endpoint}",
        "openai_api_key": "${config.agent_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d6508-40a2-7d43-b07b-4c43cd4fba45",
      "agent": "019def98-c3ab-7de1-adfd-6d3aabec7382"
    }
  },
  "experimental_features": [
    "docker"
  ]
}