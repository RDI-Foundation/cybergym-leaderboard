{
  manifest_version: "0.1.0",
  components: {
    gateway: {
      manifest: "./gateway.json5",
      config: {
        assessment_config: {
          level: "level1",
        },
        participant_roles: {
          green: "green",
          purple1: "agent",
        },
        callback_urls: {
          green:   "${bindings.green-proxy.url}",
        },
      },
    },
    green: {
      manifest: "./cybergym-green.json5",
      config: {
        task: "arvo:47101",
        vul_image: "n132/arvo:47101-vul",
        fix_image: "n132/arvo:47101-fix",
        executor_command: "/bin/arvo",
      },
    },
    agent: {
      manifest: "./cybergym-purple.json5",
      config: {
      },
    },
  },
  bindings: [
    { to: "#gateway.green",   from: "#green.a2a" },
    { to: "#gateway.purple1", from: "#agent.a2a" },
    { to: "#green.proxy",  from: "#gateway.proxy", weak: true, name: "green-proxy" },
  ],
  exports: { results: "#gateway.results" },
}
