{
  manifest_version: "0.1.0",
  components: {
    program: {
      manifest: "./cybergym-green-program.json5",
      config: {
        task: "${config.task}",
      },
    },
    vul_executor: {
      manifest: "./cybergym-executor.json5",
      config: {
        image: "${config.vul_image}",
        executor_command: "${config.executor_command}",
      },
    },
    fix_executor: {
      manifest: "./cybergym-executor.json5",
      config: {
        image: "${config.fix_image}",
        executor_command: "${config.executor_command}",
      },
    },
  },
  config_schema: {
    type: "object",
    properties: {
      task: { type: "string" },
      vul_image: { type: "string" },
      fix_image: { type: "string" },
      executor_command: { type: "string" },
    },
    required: ["task", "vul_image", "fix_image", "executor_command"],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a" },
  },
  bindings: [
    { to: "#program.vul",   from: "#vul_executor.http" },
    { to: "#program.fix",   from: "#fix_executor.http" },
    { to: "#program.proxy", from: "self.proxy" },
  ],
  exports: {
    a2a: "#program.a2a",
  },
}
